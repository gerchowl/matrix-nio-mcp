# Required — Matrix credentials
MATRIX_HOMESERVER=https://matrix.example.com
MATRIX_USER_ID=@bot:example.com
MATRIX_ACCESS_TOKEN=syt_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — device identity (recommended for stable E2EE key continuity)
MATRIX_DEVICE_ID=ABCDEFGHIJ
MATRIX_DEVICE_NAME=matrix-nio-mcp

# Optional — E2EE key store location (default: ~/.local/share/matrix-nio-mcp/store)
MATRIX_STORE_PATH=/data/store

# Optional — sync long-poll timeout in milliseconds (default: 30000)
MATRIX_SYNC_TIMEOUT=30000

# Optional — trust policy for E2EE key requests: TOFU or VERIFIED (default: TOFU)
MATRIX_TRUST_POLICY=TOFU

# Optional — MCP transport: "stdio" (default) or "sse"
MCP_TRANSPORT=stdio

# Optional — SSE server port when MCP_TRANSPORT=sse (default: 8000)
MCP_SSE_PORT=8000

# Optional — log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# Optional — log format: "json" (default) or "pretty" (human-readable)
LOG_FORMAT=json
